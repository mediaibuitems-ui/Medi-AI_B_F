{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "dotnet",
			"type": "process",
			"args": [
				"build",
				"${workspaceFolder}/Medi_AI_Backend_railway/Backend-APIs/Backend-APIs.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"problemMatcher": "$msCompile"
		},
		{
			"label": "Run Backend (Hot Reload)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"run",
				"--launch-profile",
				"http",
				"--project",
				"Medi_AI_Backend_railway/Backend-APIs/Backend-APIs.csproj"
			],
			"isBackground": true,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Run Backend (PC)",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"watch",
				"run",
				"--launch-profile",
				"http",
				"--project",
				"Medi_AI_Backend_railway/Backend-APIs/Backend-APIs.csproj"
			],
			"isBackground": true,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		}
	]
}